UPSTREAM_API_KEY=your_groq_api_key_here
UPSTREAM_BASE_URL=https://api.groq.com/openai/v1
UPSTREAM_MODEL=llama-3.3-70b-versatile
JUDGE_MODEL=llama-3.1-8b-instant
REDIS_URL=redis://localhost:6379
BLOCK_THRESHOLD=0.75
REGEX_HARD_BLOCK=0.90
SESSION_TTL=3600
# Path to custom DistilBERT classifier (default: ./injection-classifier)
# ML_MODEL_PATH=./injection-classifier
# ML enabled: set false for regex-only demo when no model is present
ML_ENABLED=true
LLM_JUDGE_ENABLED=true
